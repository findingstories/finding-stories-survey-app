# PostgreSQL connection string
# Railway auto-injects this when you add the Postgres plugin
DATABASE_URL="postgresql://postgres:password@localhost:5432/survey_app"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Your deployed app URL (no trailing slash)
AUTH_URL="https://your-app.up.railway.app"

# Resend API key for invite emails (https://resend.com)
# Optional: if not set, invite links are shown in the UI instead of being emailed
RESEND_API_KEY="re_your_key_here"
